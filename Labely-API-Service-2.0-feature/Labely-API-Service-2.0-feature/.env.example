# Environment
ENVIRONMENT=development
DEBUG=true

# Application
SECRET_KEY=your-secret-key-here-change-in-production
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=your-password
DB_NAME=label_generator_update

# Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@example.com

# Mirakl
MIRAKL_BASE_URL=https://your-mirakl-instance.mirakl.net
MIRAKL_API_KEY=your-api-key
MIRAKL_SHOP_ID=your-shop-id

# SRP
SRP_ENDPOINT_URI=https://label.terone.showroomprive.net/your-endpoint
SRP_USERNAME=your-username
SRP_CLIENT_ID=your-client-id
SRP_PASSWORD=your-password